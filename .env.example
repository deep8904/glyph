# Supabase — copy to .env.local and fill in your project values.
# Find these in: Supabase Dashboard → Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public/anon key. Supabase introduced a new key format in 2025:
#   - New format:  sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx   (recommended)
#   - Legacy:      the long "anon" JWT (eyJ...)
# Either works as the publishable key. This project reads NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key
